# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-32-bytes-min
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123

# Postgres for n8n + memory state
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=n8n
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# API keys
OPENAI_API_KEY=
TAVILY_API_KEY=

# Constraint defaults
MAX_CONTEXT_TOKENS_PER_CALL=2000
MAX_SESSION_COST_USD=0.05
MAX_RUNTIME_SECONDS=480

# Model profile
MODEL_RESEARCH=gpt-4.1
MODEL_COMPRESSION=gpt-4.1-mini
MODEL_VERIFIER=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
